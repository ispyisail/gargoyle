#!/bin/sh
# ota_upgrade -- operator-facing entry point for RFC #62 signed OTA upgrade.
# The implementation lives in usr/lib/gargoyle/ota_upgrade.sh (also used
# directly by the CGI wrapper and the phase C5 autocheck cron job); this
# wrapper exists so `ota_upgrade check` works from an interactive shell or a
# cron line without spelling out the lib path, matching sysupgrade/opkg.
exec /usr/lib/gargoyle/ota_upgrade.sh "$@"
