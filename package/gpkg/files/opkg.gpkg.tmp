src/gz %d_%V_base %U/packages/%A/base
src/gz %d_%V_packages %U/packages/%A/packages
src/gz %d_%V_routing %U/packages/%A/routing
src/gz %d_%V_telephony %U/packages/%A/telephony

# Gargoyle plugin feed, hosted on GitHub Releases (RFC #99). Keyed by libc
# ARCH (%A), not target/profile: gargoyle plugins are per-arch and several
# targets share one arch, so an arch-keyed feed avoids publishing identical
# packages once per profile. The release tag "plugins-<major>-<arch>" is the
# feed's download base; opkg fetches <base>/Packages.gz and every package's
# Filename from that same base (opkg has no absolute-URL Filename support --
# verified in libopkg/opkg_download.c -- so index and .ipks MUST share one
# release, which GitHub Releases gives us for free). The feed's Packages is
# usign-signed with the Gargoyle OTA key; its public half is baked into
# /etc/opkg/keys below so signature verification stays on.
#
# No separate "_kernelspecific" feed line: this fork builds no gargoyle
# kernel-tied packages outside the arch feed (bwmon-gargoyle etc. are arch
# packages living in the same feed), so a second feed would only ever be
# empty and make opkg warn on every update.
src/gz gargoyle https://github.com/ispyisail/gargoyle-firmware/releases/download/plugins-%G-%A

# apk backend connection info (GPKG_BACKEND=apk only, see conf.c/gpkg.c --
# gapk Phase 3/7). Inert for the default legacy backend above. Uses the
# same version/board/profile substitution tokens as the gargoyle src/gz
# lines above, nested under an "apk" segment so the two feed formats can
# be served side by side from the same release tree without colliding.
# (Written in prose, not the literal token characters, since this whole
# file gets blanket sed-substituted at build time -- literal tokens in a
# comment would get mangled the same as everywhere else.)
#
# Deliberately no arch segment on this URL, unlike the ipk src/gz lines
# above -- confirmed live that `apk`'s own `--print-arch` (e.g. "x86",
# not the ipk-side arch string like "i386_pentium4") gets appended by
# apk itself when it fetches "<apk_repository>/<its own arch>/
# APKINDEX.tar.gz". Adding an arch segment here too would double it up
# and 404.
apk_root /
apk_repository http://www.gargoyle-router.com/packages/gargoyle-%G/%T/%F/apk
apk_keys_dir /etc/gargoyle/apk-keys

dest root /
dest ram /tmp
dest plugin_root /plugin_root
lists_dir ext /var/opkg-lists
option overlay_root /overlay

# Verify every package list's usign signature (Packages.sig) against a
# trusted key in /etc/opkg/keys before trusting it -- fail-closed, so an
# unsigned or wrongly-signed feed is rejected rather than installed. The
# Gargoyle plugin feed is signed with the OTA key (baked in above); the
# OpenWrt base feeds carry OpenWrt's own key (also baked in). A feed that
# fails to download at all is skipped exactly as before, unaffected by this.
option check_signature 1
