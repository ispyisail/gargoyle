apk declares lua/host only as HOST_BUILD_DEPENDS, i.e. a dependency of
apk's own host build. But the TARGET package's meson configure also
requires lua5.1 on the host (meson.build hard-requires it for the help
system: "Program 'lua5.1' not found"). In a configuration where nothing
ever builds apk/host -- which is Gargoyle's, since gpkg (not USE_APK)
is the default package manager and apk-mbedtls is only selected as a
target package -- lua/host never enters the build graph at all, and
every from-scratch build fails at package/system/apk/compile with the
error swallowed by the build wrappers. Declare the dependency for the
target build too.

--- a/package/system/apk/Makefile
+++ b/package/system/apk/Makefile
@@ -16,6 +16,7 @@ PKG_INSTALL:=2

 HOST_BUILD_PREFIX:=$(STAGING_DIR_HOST)
 HOST_BUILD_DEPENDS:=lua/host
+PKG_BUILD_DEPENDS:=lua/host

 include $(INCLUDE_DIR)/package.mk
 include $(INCLUDE_DIR)/host-build.mk
